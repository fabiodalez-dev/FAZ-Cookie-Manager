msgid "Always Active"
msgstr "Vždy aktivní"

# =================
# Dashboard plugin
# =================
msgid "Monitor pageviews, consent behaviour, and the health of your privacy setup at a glance."
msgstr "Prohlížejte záznamy o souhlasu, filtrujte aktivity a exportujte auditní data, kdykoli to potřebujete."

msgid "Configure layout, copy, colours, and consent behaviour without leaving the editor flow."
msgstr "Nastavte rozvržení, text, barvy a chování při udělování souhlasu, aniž byste museli opustit editor."

msgid "Review discovered cookies, categorise them, run scans, and keep your declarations current."
msgstr "Prohlédněte si nalezené soubory cookie, roztřiďte je, spusťte kontrolu a udržujte své prohlášení v aktuálním stavu."

msgid "Inspect consent records, filter activity, and export audit data when you need it."
msgstr "Kontrolujte záznamy souhlasů, filtrujte aktivitu a exportujte auditní data, kdykoli je potřebujete."

msgid "Control Google Consent Mode defaults and updates with a clearer view of every signal."
msgstr "Upravujte výchozí nastavení a aktualizace režimu souhlasu Google a získejte přehlednější přehled o všech signálech."

msgid "Manage available languages and keep translated banner content organised."
msgstr "Spravujte dostupné jazyky a udržujte přeložený obsah bannerů přehledně uspořádaný."

msgid "Tune privacy, logging, scanner, and integration settings from one backend workspace."
msgstr "Nastavte parametry ochrany osobních údajů, protokolování, skeneru a integrace z jednoho backendového pracovního prostoru."

msgid "Browse IAB TCF vendors, review their declared purposes, and select which vendors your site works with."
msgstr "Projděte si seznam poskytovatelů IAB TCF, zkontrolujte jejich deklarované účely a vyberte, s kterými poskytovateli váš web spolupracuje."

msgid "Move settings safely between environments and keep repeatable backups close at hand."
msgstr "Bezpečně přenášejte nastavení mezi prostředími a mějte po ruce zálohy, které lze kdykoli obnovit."

msgid "Check environment details, plugin health, and runtime dependencies before troubleshooting."
msgstr "Před řešením problémů zkontrolujte podrobnosti o prostředí, stav pluginu a běhové prostředí."

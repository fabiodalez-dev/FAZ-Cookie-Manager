#. Plugin Name of the plugin
#: faz-cookie-manager.php
msgid "FAZ Cookie Manager"
msgstr "FAZ Cookie Manager"

#. Plugin URI of the plugin
#: faz-cookie-manager.php
msgid "https://github.com/fabiodalez-dev/faz-cookie-manager"
msgstr "https://github.com/fabiodalez-dev/faz-cookie-manager"

#. Description of the plugin
#: faz-cookie-manager.php
msgid ""
"A comprehensive GDPR/CCPA cookie consent manager with built-in cookie "
"scanner, local consent logging, Google Consent Mode v2, and IAB TCF v2.3 "
"support."
msgstr ""
"Un gestionnaire complet de consentement aux cookies conforme au GDPR/CCPA "
"avec scanner de cookies intégré, journalisation locale du consentement, "
"Google Consent Mode v2 et support IAB TCF v2.3."

#. Author of the plugin
#: faz-cookie-manager.php
msgid "Fabio D'Alessandro"
msgstr "Fabio D'Alessandro"

